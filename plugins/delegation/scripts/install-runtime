#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
plugin_root=$(CDPATH= cd -- "$script_dir/.." && pwd)
version=$(sed -n '1p' "$plugin_root/VERSION")
checksums="$plugin_root/release-artifacts.sha256"

case "$(uname -s)" in
  Linux) os=linux ;;
  Darwin) os=darwin ;;
  *)
    printf '%s\n' "delegation: unsupported operating system: $(uname -s)" >&2
    exit 1
    ;;
esac

case "$(uname -m)" in
  x86_64|amd64) arch=amd64 ;;
  arm64|aarch64) arch=arm64 ;;
  *)
    printf '%s\n' "delegation: unsupported architecture: $(uname -m)" >&2
    exit 1
    ;;
esac

artifact="delegation_${version}_${os}_${arch}.tar.gz"
expected=$(awk -v name="$artifact" '$2 == name { print $1; exit }' "$checksums")
case "$expected" in
  [0-9a-fA-F][0-9a-fA-F][0-9a-fA-F][0-9a-fA-F]*) ;;
  *)
    printf '%s\n' "delegation: no pinned SHA-256 for $artifact" >&2
    exit 1
    ;;
esac
if [ "${#expected}" -ne 64 ]; then
  printf '%s\n' "delegation: invalid pinned SHA-256 for $artifact" >&2
  exit 1
fi

delegation_home=${DELEGATION_HOME:-"$HOME/.delegation"}
if [ -L "$delegation_home" ] || { [ -e "$delegation_home" ] && [ ! -d "$delegation_home" ]; }; then
  printf '%s\n' "delegation: delegation home must be a non-symlink directory: $delegation_home" >&2
  exit 1
fi
if [ ! -e "$delegation_home" ]; then
  if ! (umask 077 && mkdir -p "$delegation_home"); then
    printf '%s\n' "delegation: failed to create a private delegation home: $delegation_home" >&2
    exit 1
  fi
fi
case "$os" in
  linux)
    home_mode=$(stat -c '%a' "$delegation_home")
    home_owner=$(stat -c '%u' "$delegation_home")
    ;;
  darwin)
    home_mode=$(stat -f '%Lp' "$delegation_home")
    home_owner=$(stat -f '%u' "$delegation_home")
    ;;
esac
current_uid=$(id -u)
if [ "$home_mode" != 700 ] || [ "$home_owner" != "$current_uid" ]; then
  printf '%s\n' "delegation: delegation home must be owned by uid $current_uid with mode 0700; refusing to modify existing permissions: $delegation_home" >&2
  exit 1
fi
target_parent="$delegation_home/bin/$version"
target="$target_parent/$os-$arch"
binary="$target/delegation"
if [ -L "$target" ]; then
  printf '%s\n' "delegation: runtime target must not be a symbolic link: $target" >&2
  exit 1
fi
if [ -e "$binary" ] || [ -L "$binary" ]; then
  if [ ! -f "$binary" ] || [ -L "$binary" ] || [ ! -x "$binary" ]; then
    printf '%s\n' "delegation: installed runtime is not a regular executable: $binary" >&2
    exit 1
  fi
  if [ "$(LC_ALL=C ls -A1 "$target")" != "delegation" ]; then
    printf '%s\n' "delegation: installed runtime directory contains unexpected files: $target" >&2
    exit 1
  fi
  installed_version=$("$binary" version)
  if [ "$installed_version" != "$version" ]; then
    printf '%s\n' "delegation: installed runtime reports version $installed_version, expected $version" >&2
    exit 1
  fi
  printf '%s\n' "$binary"
  exit 0
fi
if [ -e "$target" ] && [ ! -d "$target" ]; then
  printf '%s\n' "delegation: incomplete runtime directory already exists: $target" >&2
  exit 1
fi
if [ -d "$target" ] && [ -n "$(LC_ALL=C ls -A1 "$target")" ]; then
  printf '%s\n' "delegation: incomplete runtime directory already exists: $target" >&2
  exit 1
fi
if ! command -v link >/dev/null 2>&1; then
  printf '%s\n' 'delegation: POSIX link utility is required for atomic installation' >&2
  exit 1
fi

mkdir -p "$target_parent"
staging=$(mktemp -d "$target_parent/.install-$os-$arch.XXXXXX")
archive="$staging/$artifact"
cleanup() {
  rm -rf "$staging"
}
trap cleanup EXIT HUP INT TERM

url="https://github.com/GhostFlying/delegation/releases/download/v$version/$artifact"
curl --fail --location --silent --show-error --output "$archive" "$url"

if command -v sha256sum >/dev/null 2>&1; then
  actual=$(sha256sum "$archive" | awk '{ print $1 }')
elif command -v shasum >/dev/null 2>&1; then
  actual=$(shasum -a 256 "$archive" | awk '{ print $1 }')
else
  printf '%s\n' 'delegation: sha256sum or shasum is required' >&2
  exit 1
fi
if [ "$actual" != "$expected" ]; then
  printf '%s\n' "delegation: SHA-256 mismatch for $artifact" >&2
  exit 1
fi

entries=$(tar -tzf "$archive" | sed 's#^\./##')
if [ "$entries" != "delegation" ]; then
  printf '%s\n' "delegation: unexpected files in $artifact" >&2
  exit 1
fi
entry_details=$(tar -tvzf "$archive")
case "$entry_details" in
  -*) ;;
  *)
    printf '%s\n' "delegation: $artifact must contain one regular file" >&2
    exit 1
    ;;
esac
tar -xzf "$archive" -C "$staging"
if [ ! -f "$staging/delegation" ] || [ -L "$staging/delegation" ]; then
  printf '%s\n' "delegation: $artifact did not extract a regular runtime file" >&2
  exit 1
fi
chmod 0755 "$staging/delegation"
installed_version=$("$staging/delegation" version)
if [ "$installed_version" != "$version" ]; then
  printf '%s\n' "delegation: downloaded runtime reports version $installed_version, expected $version" >&2
  exit 1
fi
rm "$archive"

if ! mkdir "$target" 2>/dev/null; then
  if [ ! -d "$target" ] || [ -L "$target" ]; then
    printf '%s\n' "delegation: runtime target appeared during installation: $target" >&2
    exit 1
  fi
fi
target_entries=$(LC_ALL=C ls -A1 "$target")
case "$target_entries" in
  "") ;;
  delegation)
    if [ ! -f "$binary" ] || [ -L "$binary" ] || [ ! -x "$binary" ]; then
      printf '%s\n' "delegation: racing runtime is not a regular executable: $binary" >&2
      exit 1
    fi
    installed_version=$("$binary" version)
    if [ "$installed_version" != "$version" ]; then
      printf '%s\n' "delegation: racing runtime reports version $installed_version, expected $version" >&2
      exit 1
    fi
    printf '%s\n' "$binary"
    exit 0
    ;;
  *)
    printf '%s\n' "delegation: runtime target contains unexpected files: $target" >&2
    exit 1
    ;;
esac

# The POSIX link utility addresses the exact destination and never treats it as a directory.
if ! link "$staging/delegation" "$binary" 2>/dev/null; then
  if [ ! -f "$binary" ] || [ -L "$binary" ] || [ ! -x "$binary" ]; then
    printf '%s\n' "delegation: failed to publish runtime without replacing another file: $binary" >&2
    exit 1
  fi
  installed_version=$("$binary" version)
  if [ "$installed_version" != "$version" ]; then
    printf '%s\n' "delegation: racing runtime reports version $installed_version, expected $version" >&2
    exit 1
  fi
fi
if [ ! -f "$binary" ] || [ -L "$binary" ] || [ ! -x "$binary" ]; then
  printf '%s\n' "delegation: published runtime is not a regular executable: $binary" >&2
  exit 1
fi
if [ "$(LC_ALL=C ls -A1 "$target")" != "delegation" ]; then
  printf '%s\n' "delegation: runtime target contains unexpected files after publication: $target" >&2
  exit 1
fi
printf '%s\n' "$binary"
